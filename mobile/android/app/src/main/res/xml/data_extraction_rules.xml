<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+ cloud backup and device-to-device transfer rules — same
  exclusions as backup_rules.xml (see there for why), duplicated because
  Android 12+ uses this schema instead of, and in preference to,
  android:fullBackupContent.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" path="app_flutter/" />
        <exclude domain="sharedpref" path="." />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" path="app_flutter/" />
        <exclude domain="sharedpref" path="." />
    </device-transfer>
</data-extraction-rules>
